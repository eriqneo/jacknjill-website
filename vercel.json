{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*\\.pdf)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/about-us",    "destination": "/about-us.html" },
    { "source": "/academics",   "destination": "/academics.html" },
    { "source": "/alumni",      "destination": "/alumni.html" },
    { "source": "/contact",     "destination": "/contact.html" },
    { "source": "/faqs",        "destination": "/faqs.html" },
    { "source": "/gallery",     "destination": "/gallery.html" },
    { "source": "/governance",  "destination": "/governance.html" },
    { "source": "/information", "destination": "/information.html" },
    { "source": "/partners",    "destination": "/partners.html" }
  ]
}
